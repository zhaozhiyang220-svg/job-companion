# 生产环境变量模板。复制为 infra/.env.prod 并填好真实值；.env.prod 不进版本库。
# 同一份文件既供 compose 插值（postgres 凭证），又作为 api 容器的 env_file。

APP_ENV=production

# --- Postgres（compose 用这三个建库；DATABASE_URL 必须与之一致）---
POSTGRES_USER=jc
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=jc
DATABASE_URL=postgresql+psycopg://jc:CHANGE_ME_strong_db_password@postgres:5432/jc

REDIS_URL=redis://redis:6379/0

# --- 安全密钥（部署时生成）---
# openssl rand -hex 32
JWT_SECRET=CHANGE_ME_64_hex_chars
JWT_ALG=HS256
JWT_EXPIRES_HOURS=720
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=CHANGE_ME_fernet_key

# --- LLM ---
DEEPSEEK_API_KEY=sk-your-deepseek-key

# --- 对外地址（magic-link 链接 base，填公网 IP）---
PUBLIC_WEB_URL=http://YOUR_PUBLIC_IP

# --- 登录邮件：留空则 magic-link 打到 api 日志（docker compose logs api）---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# --- 内部成本仪表盘密码 ---
INTERNAL_DASHBOARD_PASSWORD=CHANGE_ME_dashboard_password

# --- 暂不启用（留空）---
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_REDIRECT_URI=
SENTRY_DSN=
POSTHOG_API_KEY=
S3_BUCKET=
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
NOTIFIER_TYPE=print
