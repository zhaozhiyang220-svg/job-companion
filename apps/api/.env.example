APP_ENV=development
# 容器内服务名用 postgres/redis；本机原生跑 api 时改成 localhost
DATABASE_URL=postgresql+psycopg://jc:jc_dev@postgres:5432/jc_dev
REDIS_URL=redis://redis:6379/0

# 对外 Web 地址（magic-link 邮件里的链接 base）；生产设成 http://<公网IP> 或正式域名
PUBLIC_WEB_URL=http://localhost:3000

# JWT
JWT_SECRET=change-me-32-bytes-min
JWT_ALG=HS256
JWT_EXPIRES_HOURS=720

# 字段级加密（Fernet key, base64-urlsafe 32 bytes）
# 生成：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# 微信开放平台
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_REDIRECT_URI=http://localhost:3000/api/auth/wechat/callback

# 邮件 Magic Link（SMTP）
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# LLM（v1 实际跑 DeepSeek；MiniMax 为 legacy 占位）
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_API_BASE=https://api.minimax.chat/v1

# 监控
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# S3 兼容对象存储（生产用 Cloudflare R2 / 阿里 OSS）
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Coach 通知（print / feishu / telegram / email）
NOTIFIER_TYPE=print
FEISHU_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 内部成本仪表盘密码
INTERNAL_DASHBOARD_PASSWORD=
